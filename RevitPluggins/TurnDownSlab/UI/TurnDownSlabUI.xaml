<Window x:Class="RevitPluggins.TurnDownSlab.UI.TurnDownSlabUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Turn-Down Slab Edge"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#201F1E"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Selectable tile for a profile type (icon placeholder + label). -->
        <Style x:Key="ProfileTileStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Tile"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1.5"
                                CornerRadius="6"
                                Background="White"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Tile" Property="Background" Value="#E8F2FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="24" Background="White" CornerRadius="8" Margin="10">
        <StackPanel Width="320">
            <TextBlock Text="Turn-Down Slab Edge"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#201F1E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <GroupBox Header="Type" Padding="10" Margin="0,0,0,12">
                <StackPanel>
                    <ComboBox x:Name="CbType"
                              Height="26"
                              SelectionChanged="CbType_SelectionChanged"/>
                    <TextBlock
                               TextWrapping="Wrap"
                               FontSize="10"
                               Foreground="#888"
                               Margin="0,6,0,0"><Run Text="Pick an existing type,"/><Run Text=" or 'New from dimensions' to build one."/></TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="GbProfile" Header="Profile Shape" Padding="10" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Profile-type selector (icon placeholders) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <RadioButton x:Name="RbProfileSimple"
                                     GroupName="ProfileKind"
                                     Style="{StaticResource ProfileTileStyle}"
                                     IsChecked="True"
                                     Checked="ProfileKind_Changed">
                            <StackPanel>
                                <Canvas Width="58" Height="40">
                                    <Polygon Points="10,6 50,6 50,30 22,30"
                                             Stroke="#201F1E" StrokeThickness="1.3" Fill="#1A0078D4"/>
                                </Canvas>
                                <TextBlock Text="Simple" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="RbProfileBrick"
                                     GroupName="ProfileKind"
                                     Style="{StaticResource ProfileTileStyle}"
                                     Checked="ProfileKind_Changed">
                            <StackPanel>
                                <Canvas Width="58" Height="40">
                                    <Polygon Points="6,5 32,5 32,16 46,16 46,33 20,33"
                                             Stroke="#201F1E" StrokeThickness="1.3" Fill="#1A0078D4"/>
                                </Canvas>
                                <TextBlock Text="Brick" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Static preview, one canvas per type, swapped in code-behind -->
                    <Grid Height="150">
                        <Canvas x:Name="CanvasSimple" Width="270" Height="150" HorizontalAlignment="Center">
                            <!-- Shift so the shape's bbox center (150,70) lands on the shared center (135,72) -->
                            <Canvas.RenderTransform><TranslateTransform X="-15" Y="2"/></Canvas.RenderTransform>
                            <!-- top = Extension, right = D, bottom = W, left = sloped face -->
                            <Polygon Points="70,30 230,30 230,110 110,110"
                                     Stroke="#201F1E" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="#1A0078D4"/>
                            <TextBlock Canvas.Left="164" Canvas.Top="114" Text="W"
                                       FontWeight="Bold" FontSize="13" Foreground="#201F1E"/>
                            <TextBlock Canvas.Left="236" Canvas.Top="60" Text="D"
                                       FontWeight="Bold" FontSize="13" Foreground="#201F1E"/>
                            <!-- Angle arc at the top vertex (between the horizontal top and the slope) -->
                            <Path Stroke="#0078D4" StrokeThickness="1.2" Data="M 90,30 A 20,20 0 0 1 79,48"/>
                            <TextBlock Canvas.Left="91" Canvas.Top="38" Text="θ"
                                       FontWeight="Bold" FontSize="13" Foreground="#0078D4"/>
                        </Canvas>

                        <Canvas x:Name="CanvasBrick" Width="270" Height="150" HorizontalAlignment="Center" Visibility="Collapsed">
                            <!-- Shift so the shape's bbox center (117.5,75) lands on the shared center (135,72) -->
                            <Canvas.RenderTransform><TranslateTransform X="17.5" Y="-3"/></Canvas.RenderTransform>
                            <!-- stepped: top = Extension, upper-right = D1, lower-right = D2, bottom = W -->
                            <Polygon Points="35,30 150,30 150,70 200,70 200,120 80,120"
                                     Stroke="#201F1E" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="#1A0078D4"/>

                            <!-- Bottom dimensions: movable W (left) + fixed StandardOffset 6" (right), shared style -->
                            <Line X1="80"  Y1="123" X2="80"  Y2="148" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="150" Y1="123" X2="150" Y2="148" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="200" Y1="123" X2="200" Y2="148" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="80"  Y1="145" X2="150" Y2="145" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="150" Y1="145" X2="200" Y2="145" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="77"  Y1="148" X2="83"  Y2="142" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="147" Y1="148" X2="153" Y2="142" Stroke="#999999" StrokeThickness="1"/>
                            <Line X1="197" Y1="148" X2="203" Y2="142" Stroke="#999999" StrokeThickness="1"/>
                            <TextBlock Canvas.Left="111" Canvas.Top="125" Text="W"
                                       FontWeight="Bold" FontSize="13" Foreground="#201F1E"/>
                            <TextBlock Canvas.Left="168" Canvas.Top="125" Text="6&quot;"
                                       FontWeight="Bold" FontSize="13" Foreground="#201F1E"/>

                            <TextBlock Canvas.Left="155" Canvas.Top="42" Text="D1"
                                       FontWeight="Bold" FontSize="12" Foreground="#201F1E"/>
                            <TextBlock Canvas.Left="206" Canvas.Top="88" Text="D2"
                                       FontWeight="Bold" FontSize="12" Foreground="#201F1E"/>
                            <!-- Angle arc at the top vertex (between the horizontal top and the slope) -->
                            <Path Stroke="#0078D4" StrokeThickness="1.2" Data="M 55,30 A 20,20 0 0 1 44,48"/>
                            <TextBlock Canvas.Left="56" Canvas.Top="38" Text="θ"
                                       FontWeight="Bold" FontSize="13" Foreground="#0078D4"/>
                        </Canvas>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="GbDimensions" Header="Dimensions" Padding="10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="W (in)" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                    <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TbWidth" Text="8" Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblDepth1" Text="D (in)" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                    <TextBox  Grid.Row="1" Grid.Column="1" x:Name="TbDepth" Text="12" Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblDepth2" Text="D2 (in)" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8" Visibility="Collapsed"/>
                    <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TbDepth2" Text="15" Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,8" Visibility="Collapsed"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Slope (°)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox  Grid.Row="3" Grid.Column="1" x:Name="TbSlope" Text="60" Style="{StaticResource FieldBoxStyle}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Placement" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <RadioButton x:Name="RbWholeSlab" Content="Select Slab (All Edges)" Margin="0,0,0,8"/>
                    <RadioButton x:Name="RbSelectEos" Content="Select EOS" IsChecked="True"/>
                </StackPanel>
            </GroupBox>

            <UniformGrid Columns="2">
                <Button x:Name="BtnCreate"
                        Content="Create &amp; Place"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,5,0"
                        Click="BtnCreate_Click"/>
                <Button x:Name="BtnClose"
                        Content="Close"
                        Style="{StaticResource ModernButtonStyle}"
                        Margin="5,0,0,0"
                        IsCancel="True"
                        Click="BtnClose_Click"/>
            </UniformGrid>
        </StackPanel>
    </Border>
</Window>
